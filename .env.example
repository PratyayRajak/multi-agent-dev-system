# =============================================================================
# Multi-Agent Software Engineering System — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Command: cp .env.example .env

# ---------------------------------------------------------------------------
# REQUIRED — the system will not start without these
# ---------------------------------------------------------------------------

# Google Gemini API Key
# Get one at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here
# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scopes: repo (read + write), pull_requests (write)
GITHUB_TOKEN=your_github_token_here

# ---------------------------------------------------------------------------
# OPTIONAL — LangSmith observability (highly recommended)
# ---------------------------------------------------------------------------

# Enable tracing (set to "true" to activate)
LANGCHAIN_TRACING_V2=true

# LangSmith API Key — get from https://smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here

# Project name for grouping traces in LangSmith dashboard
LANGCHAIN_PROJECT=multi-agent-dev-system
